---
---

<section class="py-20 bg-base-200">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-5xl font-bold mb-4">Our Products</h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <div class="card bg-base-100 shadow-xl">
        <figure class="px-6 pt-6">
          <img
            src="/assets/sicacc.jpg"
            alt="SIC"
            class="rounded-xl h-48 w-full object-cover object-top"
          />
        </figure>
        <div class="card-body">
          <h3 class="card-title text-2xl">SIC</h3>
          <p class="text-base-content/80 mb-4">Enterprise Resource Planning System.</p>
          <div class="card-actions">
            <a href="https://www.sic.tecno-logica.org/" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
              Learn More
            </a>
          </div>
        </div>
      </div>

      <div class="card bg-base-100 shadow-xl">
        <figure class="px-6 pt-6">
          <img
            src="/assets/unnamed.webp"
            alt="PVenta Mobile"
            class="rounded-xl h-48 w-full object-cover object-top"
          />
        </figure>
        <div class="card-body">
          <h3 class="card-title text-2xl">PVenta Mobile App</h3>
          <p class="text-base-content/80 mb-4">Point of Sale System for Businesses.</p>
          <div class="card-actions">
            <a href="https://play.google.com/store/apps/details?id=pventa.mobile" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
              Learn More
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>