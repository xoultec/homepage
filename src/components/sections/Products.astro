---
import { Image } from 'astro:assets';
const products = [
  {
    title: "SIC",
    description: "Enterprise Resource Planning System.",
    image: "/assets/sicacc.jpg",
    link: "https://www.sic.tecno-logica.org/"
  },
  {
    title: "PVenta Mobile App",
    description: "Point of Sale System for Businesses.",
    image: "/assets/unnamed.webp",
    link: "https://play.google.com/store/apps/details?id=pventa.mobile"
  }
];
---

<section class="py-20 bg-base-200">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-5xl font-bold mb-4">Our Products</h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {products.map((product) => (
        <div class="card bg-base-100 shadow-xl">
          <figure class="px-6 pt-6">
            <Image
              src={product.image}
              alt={product.title}
              class="rounded-xl h-48 w-full object-cover object-top"
              width="400"
              height="192"
            />
          </figure>
          <div class="card-body">
            <h3 class="card-title text-2xl">{product.title}</h3>
            <p class="text-base-content/80 mb-4">{product.description}</p>
            <div class="card-actions">
              <a 
                href={product.link} 
                class="btn btn-primary" 
                target="_blank" 
                rel="noopener noreferrer"
              >
                Learn More
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>