---
import NavBar from '../components/NavBar.astro';

const projects = [
  {
    title: "SIC - Enterprise Resource Planning",
    description: "Comprehensive ERP system for managing business operations, inventory, and financial processes.",
    image: "/assets/sicacc.jpg",
    technologies: ["React", "Node.js", "PostgreSQL", "Express", "Material-UI"],
    link: "https://www.sic.tecno-logica.org/",
    github: "#",
    featured: true
  },
  {
    title: "PVenta Mobile",
    description: "Point of Sale mobile application for businesses to manage sales, inventory, and customer data.",
    image: "/assets/unnamed.webp",
    technologies: ["React Native", "Firebase", "Redux", "Stripe API"],
    link: "https://play.google.com/store/apps/details?id=pventa.mobile",
    github: "#",
    featured: true
  },
  {
    title: "SIC UI Interface",
    description: "Modern user interface design for the SIC ERP system with improved UX and accessibility.",
    image: "/assets/sic-ui.png",
    technologies: ["React", "TypeScript", "Tailwind CSS", "Figma"],
    link: "#",
    github: "#",
    featured: false
  }
];
---

<html lang="en" data-theme="corporate">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  <title>Portfolio - XoulTec</title>
  <link rel="stylesheet" href="/src/styles/global.css" />
</head>
<body>
  <NavBar />
  
  <main>
    <!-- Header Section -->
    <section class="py-20 bg-gradient-to-b from-primary/10 to-base-100">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-6">Portfolio</h1>
        <p class="text-xl md:text-2xl mb-8 text-base-content/80 max-w-3xl mx-auto">
          Explore our latest projects and innovations in software development, mobile applications, and enterprise solutions.
        </p>
      </div>
    </section>

    <!-- Featured Projects -->
    <section class="py-20">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold mb-4">Featured Projects</h2>
          <p class="text-lg text-base-content/70">Our most impactful and innovative solutions</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
          {projects.filter(project => project.featured).map((project) => (
            <div class="card bg-base-100 shadow-xl overflow-hidden">
              <figure class="relative">
                <img
                  src={project.image}
                  alt={project.title}
                  class="w-full h-64 object-cover object-top"
                  loading="lazy"
                />
                <div class="absolute top-4 right-4">
                  <div class="badge badge-primary badge-lg">Featured</div>
                </div>
              </figure>
              <div class="card-body">
                <h3 class="card-title text-2xl mb-3">{project.title}</h3>
                <p class="text-base-content/80 mb-4">{project.description}</p>
                
                <div class="mb-6">
                  <h4 class="font-semibold mb-2">Technologies Used:</h4>
                  <div class="flex flex-wrap gap-2">
                    {project.technologies.map((tech) => (
                      <span class="badge badge-outline">{tech}</span>
                    ))}
                  </div>
                </div>

                <div class="card-actions justify-between">
                  <div class="flex gap-2">
                    <a href={project.link} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
                      View Live
                    </a>
                    {project.github !== "#" && (
                      <a href={project.github} class="btn btn-outline" target="_blank" rel="noopener noreferrer">
                        GitHub
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- All Projects -->
    <section class="py-20 bg-base-200">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold mb-4">All Projects</h2>
          <p class="text-lg text-base-content/70">Complete showcase of our work</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8 max-w-7xl mx-auto">
          {projects.map((project) => (
            <div class="card bg-base-100 shadow-xl">
              <figure class="px-4 pt-4">
                <img
                  src={project.image}
                  alt={project.title}
                  class="rounded-xl h-48 w-full object-cover object-top"
                  loading="lazy"
                />
              </figure>
              <div class="card-body">
                <h3 class="card-title text-xl">{project.title}</h3>
                <p class="text-base-content/80 text-sm mb-3">{project.description}</p>
                
                <div class="mb-4">
                  <div class="flex flex-wrap gap-1">
                    {project.technologies.slice(0, 3).map((tech) => (
                      <span class="badge badge-outline badge-sm">{tech}</span>
                    ))}
                    {project.technologies.length > 3 && (
                      <span class="badge badge-ghost badge-sm">+{project.technologies.length - 3}</span>
                    )}
                  </div>
                </div>

                <div class="card-actions justify-end">
                  <a href={project.link} class="btn btn-primary btn-sm" target="_blank" rel="noopener noreferrer">
                    View
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20">
      <div class="container mx-auto px-4 text-center">
        <div class="max-w-2xl mx-auto">
          <h2 class="text-4xl font-bold mb-6">Ready to Start Your Project?</h2>
          <p class="text-lg mb-8 text-base-content/80">
            Let's discuss how we can bring your ideas to life with cutting-edge technology solutions.
          </p>
          <a href="/contact" class="btn btn-primary btn-lg">Get In Touch</a>
        </div>
      </div>
    </section>
  </main>
</body>
</html>